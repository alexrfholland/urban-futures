  "_comment": "Registry of all canonical compositor families. When you add a new compositor (runner + canonical blend + row in COMPOSITOR_RUN-INSTRUCTIONS.md §2), also append an entry here. Do not edit the archived runners or blends referenced from _archive/ subdirs; those are historical.",
  "_field_descriptions": {
    "name": "Family identifier — matches the --only / --skip CLI arg in batch_parade_timeline_4_10.py.",
    "blend": "Repo-relative path to the canonical .blend that owns the compositor graph.",
    "runner": "Repo-relative path to the thin env-driven runner (render_current_<name>.py).",
    "n_exr_inputs": "Count of distinct EXR files the runner consumes per render. Hopefully 1. Multi-state blends (ao/normals/resources/bioenvelope/shading) take >1.",
    "n_iterations_per_flow": "Render calls per run. Hopefully 1 (a single bpy.ops.render.render fires all File Output slots). >1 violates §7b of COMPOSITOR_RUN-INSTRUCTIONS.md and should be fixed.",
    "per_branch": "true = run once per scenario branch (positive/trending/priority). false = blends multiple branches in one render.",
    "scene_name": "COMPOSITOR_SCENE_NAME default — the Blender scene the runner activates.",
    "file_output_node": "Name of the CompositorNodeOutputFile node in the canonical blend. Empty string = no single File Output node (base is the exception).",
    "rebuild_file_output": "If true, the runner sets FastRunnerConfig(rebuild_file_output=True) to work around the Blender 4.2 Group→FileOutput slot-miss bug (§7d).",
    "env_vars": "All env vars the runner reads. Generic single-input runners use COMPOSITOR_EXR / COMPOSITOR_OUTPUT_DIR. Multi-input runners use family-specific names.",
    "required_exr_passes": "AOV / pass names the canonical blend's Image nodes read from each input EXR. Empty = not yet populated (requires blend inspection inside Blender).",
    "use_arboreal_mark": "true = this family composites the arboreal mark / watermark. null = not yet determined.",
    "notes": "One-line free text. Only populate for non-obvious behaviour."
  },
